{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyLargeEC2",
      "Effect": "Deny",
      "Action": "ec2:RunInstances",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "ec2:InstanceType": [
            "m5.*",
            "c5.*",
            "r5.*",
            "x1.*"
          ]
        }
      }
    }
  ]
}
